# Copy this file to .env.local and fill in real values. .env.local is
# gitignored — never commit real credentials.

# --- Next.js app (browser + server) ---
# Both are PUBLIC (exposed to the browser via the NEXT_PUBLIC_ prefix). RLS is
# the entire access-control layer here — see README.md's security model
# section before assuming anything needs to be kept more secret than this.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Local tooling only (not read by the Next.js app) ---
# Direct Postgres connection string, used by supabase/tests/rls_regression.sh,
# supabase/tools/audit_orphaned_photos.sh, and for applying migrations by hand.
SUPABASE_DB_URL=

# --- Supabase Edge Function secrets — set these on the project, NOT here ---
# supabase/functions/send-credit-app-notification reads these from the Supabase
# runtime, not from .env.local. Configure them with:
#
#   npx supabase secrets set RESEND_API_KEY=your_resend_api_key
#   npx supabase secrets set WEBHOOK_SECRET=a_long_random_string
#   npx supabase secrets set NOTIFICATION_TO_EMAILS=admin@example.com,sales@example.com
#   npx supabase secrets set NOTIFICATION_SENDER_EMAIL=website@example.com
#   npx supabase secrets set NOTIFICATION_BRAND_NAME="Your Dealership"
#
# RESEND_API_KEY           Resend API key used to send lead-notification emails.
# WEBHOOK_SECRET            Shared secret the DB webhook must send back in the
#                           x-webhook-secret header. The function is fail-closed
#                           (returns 500) if this isn't set.
# NOTIFICATION_TO_EMAILS    Comma-separated admin recipient address(es).
# NOTIFICATION_SENDER_EMAIL Verified "from" address for outbound email.
# NOTIFICATION_BRAND_NAME   Display name used in outbound email copy.
#
# The service_role key is never used anywhere in this app (by design — see
# README.md) and should never be committed or placed in .env.local.
